---
// Left-hand navigation for the Ads section.
// Single source of truth for the section's pages — used to render the nav
// and to keep every Ads page on the same template.
export const adsNav = [
  { label: "Advertising Overview", href: "/ads" },
  { label: "Publication Schedule", href: "/ads/schedule" },
  { label: "MIT Advertisers", href: "/ads/adinfo/mit" },
  { label: "Non-Profit Advertisers", href: "/ads/adinfo/nonprofit" },
  { label: "Local Advertisers", href: "/ads/adinfo/local" },
  { label: "National Advertisers", href: "/ads/adinfo/national" },
  { label: "Recruiters", href: "/ads/adinfo/recruiter" },
  { label: "Policies", href: "/ads/policies" },
  { label: "Make A Payment", href: "/ads/payment" },
  { label: "Contact Us", href: "/ads/adscontact" },
  { label: "About The Tech", href: "/about" },
  { label: "Sponsors", href: "/about/sponsors" },
];

// Normalize trailing slashes so /about/ and /about both match.
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<nav class="ads-nav" aria-label="Ads section">
  <ul>
    {adsNav.map((item) => {
      const isActive = current === item.href;
      return (
        <li>
          <a href={item.href} class={isActive ? "is-active" : ""} aria-current={isActive ? "page" : undefined}>
            {item.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .ads-nav {
    font-family: var(--font-sans);
  }

  .ads-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ads-nav li {
    margin: 0;
  }

  .ads-nav a {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-left: 3px solid transparent;
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: var(--leading-ui);
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .ads-nav a:hover {
    color: var(--color-accent);
  }

  .ads-nav a.is-active {
    border-left-color: var(--color-accent);
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
