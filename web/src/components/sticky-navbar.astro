---
import { Image } from "astro:assets";
import nameplate from "../assets/images/nameplate-logo.png";

// Sticky navbar shown on top of every page except the home page.
// Layout: [ menu ] [ nameplate logo ] [ The Tech ] ............ [ search ]
// Menu and search are placeholders for now — see menu.astro / search.astro.
---

<header class="navbar">
  <div class="navbar__inner">
    <div class="navbar__left">
      <button type="button" class="navbar__icon-btn" aria-label="Open menu" aria-haspopup="true">
        <!-- hamburger / three-bar menu icon -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>

      <a href="/" class="navbar__brand" aria-label="The Tech — home">
        <Image src={nameplate} alt="The Tech" class="navbar__logo" width={40} height={36} />
        <span class="navbar__wordmark">The Tech</span>
      </a>
    </div>

    <div class="navbar__right">
      <button type="button" class="navbar__icon-btn" aria-label="Search">
        <!-- search icon -->
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    max-width: var(--width-site);
    margin-inline: auto;
    padding: var(--space-3) var(--space-6);
  }

  .navbar__left {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .navbar__logo {
    width: 40px;
    height: auto;
    display: block;
  }

  .navbar__wordmark {
    font-family: var(--font-display);
    font-weight: 400; /* regular thickness */
    font-size: var(--text-xl);
    color: var(--color-accent);
    line-height: 1;
    white-space: nowrap;
  }

  .navbar__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2);
    background: none;
    border: none;
    color: var(--color-text); /* icons in black */
    cursor: pointer;
    border-radius: 4px;
  }

  .navbar__icon-btn:hover {
    background: var(--color-bg-subtle);
  }
</style>
