---
import StickyNavbar from "../components/sticky-navbar.astro";
import AdsNavBar from "../components/ads-nav-bar.astro";
import Base from "./base.astro";
import Footer from "../components/footer.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base>
  <StickyNavbar />
  <main class="ads-page">
    <div class="ads-page__grid">
      <aside class="ads-page__sidebar">
        <AdsNavBar />
      </aside>
      <article class="ads-page__content"> 
        {title==="Advertising at <em>The Tech</em>" ? <h1 set:html={title}></h1> : <h1>{title}</h1>}
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .ads-page {
    max-width: var(--width-wide);
    margin-inline: auto;
    padding: var(--space-12) var(--space-6);
  }

  .ads-page__grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .ads-page__sidebar {
    position: sticky;
    top: calc(var(--space-12));
  }

  .ads-page__content {
    font-family: var(--font-serif);
    color: var(--color-text);
    font-size: var(--text-md);
    line-height: var(--leading-body);
    max-width: var(--width-content);
  }

  .ads-page__content :global(h1) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .ads-page__content :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .ads-page__content :global(p) {
    margin-bottom: var(--space-4);
  }

  .ads-page__content :global(a) {
    color: var(--color-link);
    text-decoration: underline;
  }

  .ads-page__content :global(a:hover) {
    color: var(--color-link-hover);
  }

  @media (max-width: 720px) {
    .ads-page__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .ads-page__sidebar {
      position: static;
    }
  }
</style>
